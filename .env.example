# Server Configuration
NODE_ENV=development
PORT=8080
SESSION_SECRET=fb-local-clone-secret-key-change-in-production

# File Upload
MAX_FILE_SIZE=500mb
UPLOAD_DIR=/home/tukuk/myweb/uploads

# Media
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/ogg,audio/mp3
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# URLs
BASE_URL=http://localhost:8080
MEDIA_URL=/uploads

# Features
ENABLE_REGISTRATION=true
ENABLE_STORIES=true
ENABLE_LIVE_UPDATES=true
ENABLE_BUG_BOUNTY=true

# Security (intentionally weak for bug bounty practice)
ENABLE_CSRF_PROTECTION=false
ENABLE_RATE_LIMITING=true
ENABLE_XSS_PROTECTION=false
