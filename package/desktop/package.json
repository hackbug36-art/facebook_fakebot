{
  "name": "facebook-fakebot-desktop",
  "version": "3.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "build:linux": "electron-builder --linux",
    "build:windows": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -mwl",
    "dist": "electron-builder"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "express": "^5.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "electron-reload": "^2.0.0"
  },
  "build": {
    "appId": "com.hackbug36.facebookfakebot",
    "productName": "Facebook FakeBot",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg", "zip"]
    }
  }
}
